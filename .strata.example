# Strata workspace config — copy to .strata and edit
# .strata is gitignored and machine-local; never commit it.
#
# This file is included by the Makefile. Any Makefile variable can be set here.
# Unset vars fall back to the playground defaults (gcs_analytics).

# LookML repo to analyse
# REPO = /path/to/your/lookml

# Warehouse schema facts JSON (omit for L0-only / structural analysis)
# SCHEMA = /path/to/schema_facts.json
